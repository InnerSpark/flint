{
  "name": "@innerspark/flint",
  "version": "1.6.1",
  "description": "Flint Design System tokens (color, type, spacing, radius) shared across AccessSpark and its sister brands. Tokens only, framework-agnostic.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Inner Spark Media, LLC",
  "repository": {
    "type": "git",
    "url": "https://github.com/InnerSpark/flint"
  },
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "tokens.json",
    "dist",
    "scripts",
    "mui"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.json": "./tokens.json",
    "./tokens.css": "./dist/tokens.css",
    "./tokens.media.css": "./dist/tokens.media.css",
    "./fonts.css": "./dist/fonts.css",
    "./tokens.dtcg.json": "./dist/tokens.dtcg.json",
    "./mui": {
      "types": "./mui/index.d.ts",
      "import": "./mui/index.mjs"
    }
  },
  "scripts": {
    "build": "node scripts/build.mjs && node scripts/check-contrast.mjs",
    "check": "node scripts/check-contrast.mjs",
    "prepare": "node scripts/build.mjs && node scripts/check-contrast.mjs"
  },
  "peerDependencies": {
    "@mui/material": ">=5"
  },
  "peerDependenciesMeta": {
    "@mui/material": {
      "optional": true
    }
  }
}
